# Runtime environment
APP_ENV=prod
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-internal-token

# Dev-only artifacts directory for test scripts and generated files
ARTIFACTS_DIR=./dev/output

# OpenAI-compatible API configuration (required for image description)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048

# Local embedding model (auto-downloaded on first run)
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=auto

# Qdrant local storage
QDRANT_PATH=./qdrant_data
COLLECTION_NAME=photo_rag

# Image source directory
IMAGE_DIR=./data/images

# Ingest behavior
BATCH_SIZE=1
SKIP_EXISTING=true
DEFAULT_USER_ID=0
