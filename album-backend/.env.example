# Spring Boot datasource
SPRING_DATASOURCE_URL=jdbc:sqlite:/data/photo.db

# File storage
UPLOAD_BASE_PATH=/data/uploads
UPLOAD_TEMP_PATH=/data/uploads/temp

# Face service
FACE_MODEL_ENABLED=true
FACE_MODEL_BASE_URL=http://face-recognition:8001
FACE_MODEL_INFER_PATH=/api/v1/infer
FACE_MODEL_TIMEOUT_MS=120000
FACE_MODEL_COVERS_DIR=/data/covers

# RAG integration
RAG_BASE_URL=http://rag:8003
RAG_LLM_ENABLED=true
RAG_LLM_API_KEY=your-api-key
RAG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_LLM_MODEL=qwen-vl-max
RAG_LLM_TIMEOUT_MS=120000

# Bootstrap default accounts. Override these before first initialization in production.
INIT_ADMIN_USERNAME=superadmin
INIT_ADMIN_PASSWORD=admin123456
INIT_ADMIN_EMAIL=superadmin@example.com
INIT_ADMIN_NICKNAME=Super Admin
INIT_USER_USERNAME=normaluser
INIT_USER_PASSWORD=user123456
INIT_USER_EMAIL=user@example.com
INIT_USER_NICKNAME=Normal User
